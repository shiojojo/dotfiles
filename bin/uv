#!/bin/sh
if [ "$1" = "tool" ] && [ "$2" = "run" ]; then
    echo "🚨 [Harness Guard] uv tool run による一時ツールの実行はブロックされました。" >&2
    exit 1
fi

SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
_real="$(PATH="${PATH#*$SELF_DIR:}" command -v uv)"

if [ -z "$_real" ]; then
    echo "❌ 本物の uv が見つかりません。" >&2
    exit 1
fi
exec "$_real" "$@"
