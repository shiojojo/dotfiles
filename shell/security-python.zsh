# ============================================================
# Python セキュリティ設定 (Harness Engineering)
#
# 目的: サプライチェーン攻撃対策として pip を無効化し
#       uv に一本化する。
# 読込: ~/Works/dotfiles/shell/*.zsh として自動ロード
# ============================================================

# ------------------------------------------------------------
# 1. 仮想環境の強制 (環境汚染防止)
#
# グローバル Python 環境への直接インストールを禁止する。
# uv は仮想環境を自動管理するため、pip フォールバックを
# 防ぐ二重の安全装置として機能する。
# ------------------------------------------------------------
export PIP_REQUIRE_VIRTUALENV=true

# ------------------------------------------------------------
# 2. pip / pip3 の無効化
#
# pip は uv のセキュリティ設定（検疫期間・レジストリ固定等）を
# バイパスするため、シェルレベルで完全に上書きする。
# uv pip サブコマンドは uv のセキュリティ設定が適用されるため許可。
# ------------------------------------------------------------
pip() {
  echo "❌ pip は無効化されています (Harness Engineering)"
  echo ""
  echo "   代わりに uv を使用してください:"
  echo "     uv add <package>          # プロジェクトへの追加"
  echo "     uv pip install <package>  # pip 互換コマンド"
  echo "     uv tool install <package> # グローバルツール"
  return 1
}

pip3() {
  pip "$@"
}

# ------------------------------------------------------------
# 3. uv ショートカット
# ------------------------------------------------------------
alias uv-config="cat ~/.config/uv/uv.toml"