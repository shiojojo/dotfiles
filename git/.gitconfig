# Shared Git defaults for this dotfiles repo.
# Keep user identity/signing settings out of this file.

[core]
    # Global ignore file managed by dotfiles.
    excludesfile = ~/.gitignore_global

[fetch]
    # Verify object integrity when fetching from remotes.
    fsckObjects = true

[transfer]
    # Verify object integrity during pack transfer.
    fsckObjects = true

[protocol "file"]
    # Block file:// protocol to reduce malicious local-path dependency/submodule abuse.
    allow = never

[http]
    # Always verify TLS certificates for HTTPS remotes.
    sslVerify = true
